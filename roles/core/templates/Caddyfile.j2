# Généré par Ansible — bye-google reverse-proxy
{
{% if not tls_internal %}
    email {{ acme_email }}
{% endif %}
    admin off
}

{# Upstreams : DNS du conteneur, ou 127.0.0.1:<port> quand Caddy est natif #}
{% set NAT = (caddy_mode == 'native') %}
{% set up_authelia  = '127.0.0.1:' ~ native_ports.authelia  if NAT else 'authelia:9091' %}
{% set up_homepage  = '127.0.0.1:' ~ native_ports.homepage  if NAT else 'homepage:3000' %}
{% set up_nextcloud = '127.0.0.1:' ~ native_ports.nextcloud if NAT else 'nextcloud:80' %}
{% set up_immich    = '127.0.0.1:' ~ native_ports.immich    if NAT else 'immich-server:2283' %}
{% if NAT %}
{%   set up_minio_api = '127.0.0.1:' ~ native_ports.minio_api %}
{%   set up_minio_con = '127.0.0.1:' ~ native_ports.minio_console %}
{% elif minio_mode == 'native' %}
{%   set up_minio_api = 'host.docker.internal:' ~ native_ports.minio_api %}
{%   set up_minio_con = 'host.docker.internal:' ~ native_ports.minio_console %}
{% else %}
{%   set up_minio_api = 'minio:9000' %}
{%   set up_minio_con = 'minio:9001' %}
{% endif %}

# ── Snippets réutilisables ──────────────────────────────────────────────
(tls_conf) {
{% if tls_internal %}
    tls internal
{% endif %}
}

(secure_headers) {
    header {
        Strict-Transport-Security "max-age=31536000;"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
}

# Protège un site derrière le SSO Authelia
(authelia) {
    forward_auth {{ up_authelia }} {
        uri /api/authz/forward-auth
        copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
    }
}

# Journal d'accès JSON -> lu par CrowdSec (détection d'attaques HTTP).
# Vide (no-op) si CrowdSec / le parsing des logs est désactivé.
(logging) {
{% if enable_crowdsec and crowdsec_caddy_logs | default(true) %}
    log {
        output file /var/log/caddy/access.log {
            roll_size 10MiB
            roll_keep 5
        }
        format json
    }
{% endif %}
}

# ── Portail SSO ─────────────────────────────────────────────────────────
auth.{{ domain }} {
    import tls_conf
    import secure_headers
    import logging
    reverse_proxy {{ up_authelia }}
}

# ── Dashboard (protégé par SSO) ─────────────────────────────────────────
home.{{ domain }} {
    import tls_conf
    import secure_headers
    import logging
    import authelia
    reverse_proxy {{ up_homepage }}
}

{% if enable_nextcloud %}
# ── Nextcloud ───────────────────────────────────────────────────────────
cloud.{{ domain }} {
    import tls_conf
    import secure_headers
    import logging
    redir /.well-known/carddav /remote.php/dav 301
    redir /.well-known/caldav /remote.php/dav 301
    reverse_proxy {{ up_nextcloud }}
}
{% endif %}

{% if enable_immich %}
# ── Immich (photos) ─────────────────────────────────────────────────────
photos.{{ domain }} {
    import tls_conf
    import secure_headers
    import logging
    reverse_proxy {{ up_immich }}
}
{% endif %}

{% if enable_minio %}
# ── MinIO : API S3 + console ────────────────────────────────────────────
s3.{{ domain }} {
    import tls_conf
    import logging
    reverse_proxy {{ up_minio_api }}
}
minio.{{ domain }} {
    import tls_conf
    import secure_headers
    import logging
    reverse_proxy {{ up_minio_con }}
}
{% endif %}

# ── Apps perso (mini-PaaS) : routes générées dans /etc/caddy/apps/*.caddy ─
import /etc/caddy/apps/*.caddy
