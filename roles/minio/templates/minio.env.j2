# Généré par Ansible — bye-google / MinIO natif
{% set minio_bind = '127.0.0.1' if caddy_native | bool else '0.0.0.0' %}
MINIO_ROOT_USER={{ minio_root_user }}
MINIO_ROOT_PASSWORD={{ vault_minio_root_password }}
MINIO_VOLUMES={{ data_root }}/minio/data
MINIO_OPTS=--address {{ minio_bind }}:{{ native_ports.minio_api }} --console-address {{ minio_bind }}:{{ native_ports.minio_console }}
MINIO_SERVER_URL=https://s3.{{ domain }}
MINIO_BROWSER_REDIRECT_URL=https://minio.{{ domain }}
